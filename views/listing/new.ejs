<% layout("layouts/boilerplate") %>
  <div class="row justify-content-center">

    <div class="col-lg-6 col-md-8">

      <div class="new-form-container">

        <h2 class="mb-4 fw-bold">
          Create a New Listing
        </h2>

        <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

          <!-- TITLE -->

          <div class="mb-3">

            <label class="form-label">
              Title
            </label>

            <input name="listing[title]" placeholder="Enter title" type="text" class="form-control" required />
            <div class="invalid-feedback">
              Please enter a title
            </div>

          </div>

          <!-- DESCRIPTION -->

          <div class="mb-3">

            <label class="form-label">
              Description
            </label>

            <textarea name="listing[description]" placeholder="Enter description" class="form-control "
              rows="4" required ></textarea>
              <div class="invalid-feedback">
    Please enter a description
</div>

          </div>

          <!-- IMAGE -->

          <div class="mb-3">
   <label class="form-label">
      Upload Image
   </label>

   <input
      type="file"
      name="listing[image]"
      class="form-control"
      required
   >
</div>

          <!-- PRICE -->

          <div class="mb-3">

            <label class="form-label">
              Price
            </label>

            <input name="listing[price]" placeholder="Enter price" type="number" class="form-control "
              required  />
              <div class="invalid-feedback">
    Please enter a price
</div>

          </div>

          <!-- COUNTRY -->

          <div class="mb-3">

            <label class="form-label">
              Country
            </label>

            <input name="listing[country]" placeholder="Enter country" type="text" class="form-control "
              required  />
              <div class="invalid-feedback">
    Please enter a country
</div>

          </div>

          <!-- LOCATION -->

          <div class="mb-4">

            <label class="form-label">
              Location
            </label>

            <input name="listing[location]" placeholder="Enter location" type="text"
              class="form-control needs-validation" required novalidate />
              <div class="invalid-feedback">
    Please enter a location
</div>

          </div>
          <!-- category -->
          <div class="mb-3">

            <label class="form-label">
              Category
            </label>

            <select name="listing[category]" class="form-select" required >

              <option value="Beach">Beach</option>

              <option value="Mountains">Mountains</option>

              <option value="Forest">Forest</option>

              <option value="Arctic">Arctic</option>

              <option value="Homes">Homes</option>

            </select>
            <div class="invalid-feedback">
    Please enter a category
</div>

          </div>
          <!-- BUTTON -->

          <button class="btn add-btn">
            Add Listing
          </button>

        </form>

      </div>

    </div>

  </div>